{
  "name": "workspace-script-runner",
  "displayName": "Workspace Script Runner",
  "description": "Run npm scripts with intuitive UI, multi-root workspace support, and auto package manager detection",
  "version": "1.0.3",
  "publisher": "ducdev2k1",
  "openvsx": {
    "publisher": "ducdev2k1"
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ducdev2k1/workspace-script-runner"
  },
  "bugs": {
    "url": "https://github.com/ducdev2k1/workspace-script-runner/issues"
  },
  "homepage": "https://github.com/ducdev2k1/workspace-script-runner#readme",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scriptsRunnerContainer",
          "title": "Scripts Runner",
          "icon": "resources/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "scriptsRunnerContainer": [
        {
          "id": "scriptsRunnerView",
          "name": "All Scripts",
          "icon": "$(list-tree)"
        },
        {
          "id": "scriptsRunnerRunningView",
          "name": "Running Scripts",
          "icon": "$(sync~spin)"
        }
      ]
    },
    "commands": [
      {
        "command": "scriptsRunner.runScript",
        "title": "Run Script",
        "category": "Scripts Runner",
        "icon": {
          "light": "resources/icons/play.svg",
          "dark": "resources/icons/play.svg"
        }
      },
      {
        "command": "scriptsRunner.stopScript",
        "title": "Stop Script",
        "category": "Scripts Runner",
        "icon": {
          "light": "resources/icons/stop.svg",
          "dark": "resources/icons/stop.svg"
        }
      },
      {
        "command": "scriptsRunner.restartScript",
        "title": "Restart Script",
        "category": "Scripts Runner",
        "icon": {
          "light": "resources/icons/reload.svg",
          "dark": "resources/icons/reload.svg"
        }
      },
      {
        "command": "scriptsRunner.changePackageManager",
        "title": "Change Package Manager",
        "category": "Scripts Runner"
      },
      {
        "command": "scriptsRunner.refresh",
        "title": "Refresh",
        "category": "Scripts Runner",
        "icon": "$(refresh)"
      },
      {
        "command": "scriptsRunner.focusTerminal",
        "title": "Focus Terminal",
        "category": "Scripts Runner",
        "icon": "$(terminal)"
      },
      {
        "command": "scriptsRunner.debugScript",
        "title": "Debug Script",
        "category": "Scripts Runner",
        "icon": {
          "light": "resources/icons/debug.svg",
          "dark": "resources/icons/debug.svg"
        }
      },
      {
        "command": "scriptsRunner.pinScript",
        "title": "Pin to Favorites",
        "category": "Scripts Runner",
        "icon": "$(star-empty)"
      },
      {
        "command": "scriptsRunner.unpinScript",
        "title": "Unpin from Favorites",
        "category": "Scripts Runner",
        "icon": "$(star-full)"
      },
      {
        "command": "scriptsRunner.copyCommand",
        "title": "Copy Command",
        "category": "Scripts Runner",
        "icon": "$(copy)"
      }
    ],
    "taskDefinitions": [
      {
        "type": "script-runner",
        "required": [
          "script",
          "folder"
        ],
        "properties": {
          "script": {
            "type": "string",
            "description": "Script name from package.json"
          },
          "folder": {
            "type": "string",
            "description": "Absolute path to the project folder"
          }
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "scriptsRunner.refresh",
          "when": "view == scriptsRunnerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "scriptsRunner.runScript",
          "when": "view == scriptsRunnerView && (viewItem == script || viewItem == scriptFavorite)",
          "group": "inline@1"
        },
        {
          "command": "scriptsRunner.debugScript",
          "when": "view == scriptsRunnerView && (viewItem == script || viewItem == scriptFavorite)",
          "group": "inline@2"
        },
        {
          "command": "scriptsRunner.stopScript",
          "when": "view == scriptsRunnerView && (viewItem == scriptRunning || viewItem == scriptFavoriteRunning)",
          "group": "inline@1"
        },
        {
          "command": "scriptsRunner.restartScript",
          "when": "view == scriptsRunnerView && (viewItem == scriptRunning || viewItem == scriptFavoriteRunning)",
          "group": "inline@2"
        },
        {
          "command": "scriptsRunner.stopScript",
          "when": "view == scriptsRunnerView && (viewItem == scriptDebugging || viewItem == scriptFavoriteDebugging)",
          "group": "inline@1"
        },
        {
          "command": "scriptsRunner.pinScript",
          "when": "view == scriptsRunnerView && (viewItem == script || viewItem == scriptRunning || viewItem == scriptDebugging)",
          "group": "context@1"
        },
        {
          "command": "scriptsRunner.unpinScript",
          "when": "view == scriptsRunnerView && (viewItem == scriptFavorite || viewItem == scriptFavoriteRunning || viewItem == scriptFavoriteDebugging)",
          "group": "context@1"
        },
        {
          "command": "scriptsRunner.copyCommand",
          "when": "view == scriptsRunnerView",
          "group": "context@2"
        },
        {
          "command": "scriptsRunner.stopScript",
          "when": "view == scriptsRunnerRunningView && viewItem == runningScript",
          "group": "inline@1"
        },
        {
          "command": "scriptsRunner.restartScript",
          "when": "view == scriptsRunnerRunningView && viewItem == runningScript",
          "group": "inline@2"
        },
        {
          "command": "scriptsRunner.focusTerminal",
          "when": "view == scriptsRunnerRunningView && viewItem == runningScript",
          "group": "inline@3"
        }
      ]
    },
    "configuration": {
      "title": "Scripts Runner",
      "properties": {
        "scriptsRunner.defaultPackageManager": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "npm",
            "yarn",
            "pnpm",
            "bun"
          ],
          "description": "Default package manager to use when auto-detection fails"
        },
        "scriptsRunner.workspacePackageManager": {
          "type": "object",
          "default": {},
          "description": "Override package manager for specific workspace folders. Example: { \"project-a\": \"pnpm\" }"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  }
}
